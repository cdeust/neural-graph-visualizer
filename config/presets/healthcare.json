{
  "name": "Clinical Knowledge Map",
  "accentColor": "#00d2ff",
  "nodeTypes": {
    "patient":    { "color": "#00d2ff", "shape": "sphere", "label": "Patient" },
    "diagnosis":  { "color": "#ff6b35", "shape": "hex",    "label": "Diagnosis" },
    "treatment":  { "color": "#26de81", "shape": "sphere", "label": "Treatment" },
    "lab_result": { "color": "#a55eea", "shape": "sphere", "label": "Lab Result" },
    "provider":   { "color": "#ff4081", "shape": "hex",    "label": "Provider" }
  },
  "categoryRules": {
    "cardiology":   ["heart", "cardiac", "ecg", "arrhythmia"],
    "oncology":     ["tumor", "cancer", "chemo", "radiation"],
    "radiology":    ["ct", "mri", "xray", "imaging"],
    "lab":          ["blood", "culture", "biopsy", "pathology"]
  },
  "connectionRules": {
    "sameProject":    0.3,
    "sameType":       0.2,
    "nameReference":  0.8,
    "keywordOverlap": 0.1,
    "temporalWindow": "24h"
  },
  "dataSources": [
    { "type": "directory", "path": "./data", "pattern": "**/*.md" },
    { "type": "jsonFile",  "path": "./data/graph.json" }
  ]
}
